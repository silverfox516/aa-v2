<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.aauto.app">

    <uses-feature android:name="android.hardware.usb.host" android:required="true" />
    <!-- System-level USB access without user permission dialog -->
    <uses-permission android:name="android.permission.MANAGE_USB" />
    <application
        android:name=".AaApplication"
        android:label="Android Auto"
        android:persistent="true">

        <activity
            android:name=".AaDisplayActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!-- Auto-launch for AOA devices only (Google VID 0x18D1) -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>
            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>

        <service
            android:name=".AaService"
            android:exported="false" />

    </application>
</manifest>
