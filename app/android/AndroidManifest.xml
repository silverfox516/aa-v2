<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.aauto.app">

    <uses-feature android:name="android.hardware.usb.host" android:required="true" />
    <uses-permission android:name="android.permission.MANAGE_USB" />

    <application
        android:name=".AaApplication"
        android:label="Android Auto"
        android:persistent="true">

        <!-- Home screen: device list -->
        <activity
            android:name=".DeviceListActivity"
            android:exported="true"
            android:launchMode="singleTask">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

        </activity>

        <!-- AA video display (launched by Service on session start) -->
        <activity
            android:name=".AaDisplayActivity"
            android:exported="false"
            android:theme="@android:style/Theme.NoTitleBar.Fullscreen" />

        <service
            android:name=".AaService"
            android:exported="false" />

    </application>
</manifest>
