// aa-v2 core unit tests

cc_test {
    name: "aauto_core_test",
    cpp_std: "c++17",
    cflags: [
        "-Wall",
        "-Wextra",
        "-Werror",
        "-Wno-unused-private-field",
        "-Wno-implicit-fallthrough",
        "-DASIO_STANDALONE",
        "-DASIO_NO_DEPRECATED",
    ],
    rtti: true,
    cppflags: [
        "-fexceptions",
    ],
    local_include_dirs: [
        "core/mock",
    ],
    srcs: [
        "core/placeholder_test.cpp",
        "core/framer_test.cpp",
    ],
    static_libs: [
        "libaauto-core",
    ],
    header_libs: [
        "aauto_asio_headers",
    ],
    test_suites: ["device-tests"],
}
