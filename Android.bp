// aa-v2 top-level build definition
// F.2: Android.bp (Soong) for AOSP tree integration

subdirs = [
    "core",
    "impl",
    "protobuf",
    "tests",
]

// standalone asio headers (header-only, no boost)
// Defined at root level because Soong disallows ".." in include paths.
cc_library_headers {
    name: "aauto_asio_headers",
    export_include_dirs: [
        "third_party/asio",
    ],
}
